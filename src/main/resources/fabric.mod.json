    "client": ["dev.historicaltextures.HistoricalTexturesClient"],
    "modmenu": ["dev.historicaltextures.ModMenuIntegration"]
  },
  "mixins": [
    "historical_textures.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.0",
